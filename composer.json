{
    "name": "polysource/workflow-bridge",
    "description": "Polysource — Symfony Workflow bridge: auto-generates inline transition actions + state chips for resources with a Workflow attached.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "polysource",
        "workflow",
        "symfony",
        "state-machine",
        "transitions"
    ],
    "homepage": "https://github.com/polysource/polysource",
    "support": {
        "issues": "https://github.com/polysource/polysource/issues",
        "source": "https://github.com/polysource/polysource"
    },
    "require": {
        "php": ">=8.1",
        "polysource/core": "0.1.x-dev",
        "symfony/config": "^5.4 || ^6.0 || ^7.0 || ^8.0",
        "symfony/dependency-injection": "^5.4 || ^6.0 || ^7.0 || ^8.0",
        "symfony/http-kernel": "^5.4 || ^6.0 || ^7.0 || ^8.0",
        "symfony/translation": "^5.4 || ^6.0 || ^7.0 || ^8.0",
        "symfony/workflow": "^5.4 || ^6.0 || ^7.0 || ^8.0",
        "symfony/yaml": "^5.4 || ^6.0 || ^7.0 || ^8.0",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.5",
        "polysource/symfony-bundle": "0.1.x-dev"
    },
    "autoload": {
        "psr-4": {
            "Polysource\\WorkflowBridge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Polysource\\WorkflowBridge\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    }
}
